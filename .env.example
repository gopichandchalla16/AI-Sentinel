# AI-Sentinel Environment Variables
# Copy this file to .env.local and fill in your keys

# Google Gemini AI — https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=your_google_gemini_api_key_here

# Helius RPC — https://helius.dev (free tier: 100k requests/day)
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Public RPC (used client-side, safe to expose)
NEXT_PUBLIC_HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
